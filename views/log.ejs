<!doctype html>
<html>
  <body>
    <h1>Pushups Log</h1>
    <p><a href="/analytics">View analytics</a> | <a href="/stats">Raw stats JSON</a></p>
    <p>Today: <strong><%= todayCount || 0 %></strong></p>
    <p>Total: <strong><%= lifetimeCount || 0 %></strong></p>

    <% if (message) { %>
      <p><strong><%= message %></strong></p>
    <% } %>

    <% if (error) { %>
      <p style="color:red;"><%= error %></p>
    <% } %>

    <form method="post" action="/log">
      <label>How many pushups?</label><br/>
      <input name="count" type="number" min="1" max="300" step="1" required autofocus value="<%= last || '' %>" />
      <button type="submit">Log</button>
    </form>
  </body>
</html>
