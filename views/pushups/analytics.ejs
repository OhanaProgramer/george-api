<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Pushups Analytics</title>
    <link rel="stylesheet" href="/public/styles.css" />
    <style>
      .chart-card {
        padding: 0.75rem;
      }

      .chart-shell {
        border: 1px solid #d7dee8;
        border-radius: 14px;
        background: linear-gradient(180deg, #ffffff, #f8fbff);
        padding: 0.6rem;
      }

      .chart-caption {
        margin: 0 0 0.45rem;
        color: #5a6778;
        font-size: 0.9rem;
      }

      .chart-frame {
        position: relative;
        width: 100%;
      }

      .chart-frame canvas {
        display: block;
        width: 100%;
        height: 240px;
      }

      .chart-empty {
        margin: 0;
        border: 1px dashed #c6d4e6;
        border-radius: 12px;
        background: #f7fbff;
        padding: 0.9rem;
        color: #5a6778;
      }

      .flag-box {
        border: 1px solid #ffd5c4;
        border-radius: 12px;
        background: #fff7f3;
        color: #6f2a0f;
        padding: 0.75rem 0.85rem;
        margin: 0.65rem 0 0;
      }

      .flag-box strong {
        display: block;
        margin-bottom: 0.2rem;
      }

      @media (max-width: 760px) {
        .chart-frame canvas {
          height: 220px;
        }
      }
    </style>
  </head>
  <body>
    <%
      const chartSeries = (typeof series_60d !== "undefined" && Array.isArray(series_60d)) ? series_60d : [];
      const chartAvg14 = (typeof avg_14d !== "undefined" && Array.isArray(avg_14d)) ? avg_14d : [];
      const chartTarget = (typeof target_daily === "number") ? target_daily : 0;
      const publishFlags = (typeof flags !== "undefined" && flags && typeof flags === "object") ? flags : {};
      const publishMetrics = (typeof metrics !== "undefined" && metrics && typeof metrics === "object") ? metrics : {};
      const avgRecent14 = Number.isFinite(Number(publishMetrics.avg_recent_14)) ? Number(publishMetrics.avg_recent_14) : null;
      const avgPrior14 = Number.isFinite(Number(publishMetrics.avg_prior_14)) ? Number(publishMetrics.avg_prior_14) : null;
    %>
    <main class="shell">
      <div class="topbar">
        <a href="/pushups/log">Back to log</a>
        <span class="subtle">As of <strong><%= as_of %></strong></span>
      </div>

      <section class="panel">
        <h1>Pushups Analytics</h1>
        <div class="links">
          <a class="btn-link" href="/pushups/support">Support / How this works</a>
          <a class="btn-link" href="/pushups/analytics.json">Analytics JSON</a>
          <a class="btn-link" href="/pushups/stats.json">Stats JSON</a>
          <% if (auth && auth.scope === "admin") { %>
            <a class="btn-link" href="/pushups/settings">Settings</a>
          <% } %>
        </div>

        <h2>Scorecard</h2>
        <div class="grid">
          <article class="card">
            <div class="k">Pace</div>
            <div class="v"><%= goal.on_pace_today ? "On Pace" : "Behind" %></div>
            <span class="chip <%= goal.on_pace_today ? 'good' : 'warn' %>"><%= goal.on_pace_today ? "On Track" : "Catch Up" %></span>
          </article>
          <article class="card">
            <div class="k">Ahead / Behind</div>
            <div class="v"><%= goal.ahead_behind %></div>
          </article>
          <article class="card">
            <div class="k">Required / Day</div>
            <div class="v"><%= goal.required_per_day_remaining %></div>
          </article>
          <article class="card">
            <div class="k">Projected By Target</div>
            <div class="v"><%= goal.projected_total_by_target_30d_pace %></div>
          </article>
          <article class="card">
            <div class="k">7d vs 30d</div>
            <div class="v"><%= consistency.avg_7d %> / <%= consistency.avg_30d %></div>
          </article>
          <article class="card">
            <div class="k">Active Days (30d)</div>
            <div class="v"><%= consistency.active_days_30d %></div>
          </article>
          <article class="card">
            <div class="k">Weekly Jump %</div>
            <div class="v"><%= risk.weekly_jump_pct === null ? "n/a" : risk.weekly_jump_pct %></div>
          </article>
          <article class="card">
            <div class="k">Risk</div>
            <div class="v"><%= risk.high_ramp_risk ? "High" : "Controlled" %></div>
            <span class="chip <%= risk.high_ramp_risk ? 'warn' : 'good' %>"><%= risk.high_ramp_risk ? "Watch Load" : "Stable" %></span>
          </article>
        </div>

        <h2>Chart</h2>
        <article class="card chart-card">
          <div class="chart-shell">
            <p class="chart-caption">Last 60 days (bars) + 14-day average (line)</p>
            <% if (chartSeries.length > 0) { %>
              <div class="chart-frame">
                <canvas id="pushupsChart" aria-label="Pushups last 60 days chart"></canvas>
              </div>
            <% } else { %>
              <p class="chart-empty">No chart data yet. Run rebuild.</p>
            <% } %>

            <% if (publishFlags.trend_down) { %>
              <div class="flag-box" role="status" aria-live="polite">
                <strong>Recent pace is down vs prior 2 weeks.</strong>
                <% if (avgRecent14 !== null && avgPrior14 !== null) { %>
                  <span>Recent 14d avg: <%= avgRecent14.toFixed(1) %> | Prior 14d avg: <%= avgPrior14.toFixed(1) %></span>
                <% } %>
              </div>
            <% } %>

            <% if (publishFlags.below_target_projection) { %>
              <div class="flag-box" role="status" aria-live="polite">
                <strong>Current 14-day average is below your target.</strong>
                <% if (avgRecent14 !== null) { %>
                  <span>Target: <%= chartTarget %> | Current 14d avg: <%= avgRecent14.toFixed(1) %></span>
                <% } else { %>
                  <span>Target: <%= chartTarget %></span>
                <% } %>
              </div>
            <% } %>
          </div>
        </article>

        <h2>Coach Note (Next 7 Days)</h2>
        <article class="card">
          <p class="coach"><%= coach_note %></p>
        </article>
      </section>
      <%- include("../partials/footer") %>
    </main>
    <script>
      (function () {
        const canvas = document.getElementById("pushupsChart");
        if (!canvas) return;

        const series = <%- JSON.stringify(chartSeries) %>;
        const avg14 = <%- JSON.stringify(chartAvg14) %>;
        const targetDaily = <%- JSON.stringify(chartTarget) %>;
        if (!Array.isArray(series) || series.length === 0) return;

        const frame = canvas.closest(".chart-frame");
        const ctx = canvas.getContext("2d");
        let resizeTimer = null;

        function drawChart() {
          const width = Math.max(280, Math.floor(frame.clientWidth || 0));
          const height = 240;
          const dpr = window.devicePixelRatio || 1;

          canvas.width = Math.floor(width * dpr);
          canvas.height = Math.floor(height * dpr);
          canvas.style.width = width + "px";
          canvas.style.height = height + "px";
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
          ctx.clearRect(0, 0, width, height);

          const pad = { top: 18, right: 10, bottom: 28, left: 10 };
          const plotW = width - pad.left - pad.right;
          const plotH = height - pad.top - pad.bottom;
          const left = pad.left;
          const top = pad.top;
          const bottom = top + plotH;
          const n = series.length;
          if (!n || plotW <= 0 || plotH <= 0) return;

          const totals = series.map((p) => Number(p && p.total) || 0);
          const avgs = avg14.map((p) => Number(p && p.avg) || 0);
          const maxVal = Math.max(1, ...totals, ...avgs, targetDaily > 0 ? targetDaily : 0);

          const yFor = (value) => bottom - (Math.max(0, value) / maxVal) * plotH;

          // Light reference lines keep the chart readable without a heavy axis system.
          ctx.strokeStyle = "#e6edf7";
          ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.moveTo(left, top);
          ctx.lineTo(left + plotW, top);
          ctx.moveTo(left, bottom);
          ctx.lineTo(left + plotW, bottom);
          ctx.stroke();

          ctx.fillStyle = "#5a6778";
          ctx.font = "12px sans-serif";
          ctx.fillText(String(Math.round(maxVal)), left, top - 4);

          const slotW = plotW / n;
          const barGap = n > 45 ? 1 : 2;
          const barW = Math.max(1, slotW - barGap);

          ctx.fillStyle = "rgba(31, 159, 255, 0.45)";
          for (let i = 0; i < n; i += 1) {
            const total = totals[i];
            const h = (Math.max(0, total) / maxVal) * plotH;
            const x = left + i * slotW + (slotW - barW) / 2;
            const y = bottom - h;
            ctx.fillRect(x, y, barW, h);
          }

          if (targetDaily > 0) {
            const ty = yFor(targetDaily);
            ctx.setLineDash([4, 4]);
            ctx.strokeStyle = "rgba(217, 63, 11, 0.5)";
            ctx.beginPath();
            ctx.moveTo(left, ty);
            ctx.lineTo(left + plotW, ty);
            ctx.stroke();
            ctx.setLineDash([]);
          }

          ctx.strokeStyle = "#ff6b2c";
          ctx.lineWidth = 2;
          ctx.beginPath();
          for (let i = 0; i < n; i += 1) {
            const v = avgs[i];
            const x = left + i * slotW + slotW / 2;
            const y = yFor(v);
            if (i === 0) ctx.moveTo(x, y);
            else ctx.lineTo(x, y);
          }
          ctx.stroke();

          const labelIdx = [0, Math.floor((n - 1) / 2), n - 1];
          const seen = new Set();
          ctx.fillStyle = "#5a6778";
          ctx.font = "11px sans-serif";
          ctx.textBaseline = "top";
          for (const idx of labelIdx) {
            if (seen.has(idx)) continue;
            seen.add(idx);
            const point = series[idx];
            if (!point || !point.date) continue;
            const label = String(point.date).slice(5);
            const x = left + idx * slotW + slotW / 2;
            const textW = ctx.measureText(label).width;
            const tx = Math.max(left, Math.min(left + plotW - textW, x - textW / 2));
            ctx.fillText(label, tx, bottom + 7);
          }
        }

        function debounceRedraw() {
          window.clearTimeout(resizeTimer);
          resizeTimer = window.setTimeout(drawChart, 120);
        }

        drawChart();
        window.addEventListener("resize", debounceRedraw);
      })();
    </script>
  </body>
</html>
